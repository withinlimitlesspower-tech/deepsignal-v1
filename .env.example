# =============================================================================
# AI Trading Bot - Environment Configuration
# =============================================================================
# This file contains all environment variables required by the AI-powered
# trading bot. Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Binance API Configuration
# ---------------------------------------------------------------------------
# Get your API keys from: https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
# Use testnet for development: https://testnet.binance.com/

# Binance API Key (required for authenticated requests)
BINANCE_API_KEY=your_binance_api_key_here

# Binance Secret Key (required for authenticated requests)
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Binance API Base URL
# Production: https://api.binance.com
# Testnet: https://testnet.binance.vision
BINANCE_BASE_URL=https://api.binance.com

# WebSocket URL for real-time data
# Production: wss://stream.binance.com:9443/ws
# Testnet: wss://testnet.binance.vision/ws
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# ---------------------------------------------------------------------------
# DeepSeek AI Model Configuration
# ---------------------------------------------------------------------------
# Get your DeepSeek API key from: https://platform.deepseek.com/

# DeepSeek API Key (required for AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek Model Version (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API Base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Maximum tokens for AI response (adjust based on analysis complexity)
DEEPSEEK_MAX_TOKENS=4096

# Temperature for AI response (0.0 = deterministic, 1.0 = creative)
DEEPSEEK_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Web Application Configuration
# ---------------------------------------------------------------------------

# Flask/FastAPI secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# Application environment (development, production, testing)
FLASK_ENV=development

# Debug mode (True/False)
DEBUG=True

# Host to bind the web server (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Port for the web server
PORT=5000

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------

# Database URL (SQLite for development, PostgreSQL for production)
# SQLite: sqlite:///trading_bot.db
# PostgreSQL: postgresql://user:password@localhost:5432/trading_bot
DATABASE_URL=sqlite:///trading_bot.db

# Redis URL for caching and session management (optional)
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Trading Bot Configuration
# ---------------------------------------------------------------------------

# Trading mode (paper/live)
TRADING_MODE=paper

# Default trading pair (e.g., BTCUSDT, ETHUSDT)
DEFAULT_SYMBOL=BTCUSDT

# Default time interval for analysis (1m, 5m, 15m, 30m, 1h, 4h, 1d, 1w)
DEFAULT_INTERVAL=1h

# Maximum position size as percentage of portfolio (0.0 - 1.0)
MAX_POSITION_SIZE=0.1

# Stop-loss percentage (e.g., 0.05 = 5%)
STOP_LOSS_PERCENT=0.05

# Take-profit percentage (e.g., 0.10 = 10%)
TAKE_PROFIT_PERCENT=0.10

# Maximum number of concurrent trades
MAX_CONCURRENT_TRADES=3

# ---------------------------------------------------------------------------
# Logging Configuration
# ---------------------------------------------------------------------------

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty for console logging only)
LOG_FILE=logs/trading_bot.log

# Maximum log file size in bytes (10 MB default)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# Security & Rate Limiting
# ---------------------------------------------------------------------------

# Rate limiting for API endpoints (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# JWT secret key for authentication (generate with: openssl rand -hex 64)
JWT_SECRET_KEY=your_jwt_secret_key_here_generate_with_openssl_rand_hex_64

# JWT token expiration time in hours
JWT_EXPIRATION_HOURS=24

# Allowed origins for CORS (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ---------------------------------------------------------------------------
# Chat History Configuration
# ---------------------------------------------------------------------------

# Maximum number of chat messages to store per user
MAX_CHAT_HISTORY_MESSAGES=100

# Chat history storage backend (database, redis, file)
CHAT_STORAGE_BACKEND=database

# Chat history retention period in days
CHAT_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Notification Configuration (Optional)
# ---------------------------------------------------------------------------

# Email settings for trade notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
NOTIFICATION_EMAIL=your_notification_email@example.com

# Telegram bot token for notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---------------------------------------------------------------------------
# Advanced Configuration (Optional - Use Defaults if Unsure)
# ---------------------------------------------------------------------------

# Technical analysis parameters
RSI_PERIOD=14
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2

# AI analysis parameters
AI_ANALYSIS_INTERVAL_MINUTES=60
AI_CONFIDENCE_THRESHOLD=0.75

# WebSocket reconnection settings
WS_RECONNECT_DELAY_SECONDS=5
WS_MAX_RECONNECT_ATTEMPTS=10